ome.js",["230","231"],[],"C:\\Users\\adith\\OneDrive\\Desktop\\Fullstack\\expense-Tracker\\frontend\\src\\Components\\Orb\\Orb.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\Fullstack\\expense-Tracker\\frontend\\src\\Components\\Expenses\\ExpenseForm.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\Fullstack\\expense-Tracker\\frontend\\src\\utils\\Icons.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\Fullstack\\expense-Tracker\\frontend\\src\\utils\\menuItems.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\Fullstack\\expense-Tracker\\frontend\\src\\History\\History.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\Fullstack\\expense-Tracker\\frontend\\src\\utils\\useWindowSize.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\Fullstack\\expense-Tracker\\frontend\\src\\Components\\Chart\\Chart.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\Fullstack\\expense-Tracker\\frontend\\src\\Components\\Form\\Form.js",["232"],[],"C:\\Users\\adith\\OneDrive\\Desktop\\Fullstack\\expense-Tracker\\frontend\\src\\Components\\IncomeItem\\IncomeItem.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\Fullstack\\expense-Tracker\\frontend\\src\\utils\\dateFormat.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\Fullstack\\expense-Tracker\\frontend\\src\\Components\\Button\\Button.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\index.js",[],[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\App.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\styles\\GlobalStyle.js",[],[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\context\\globalContext.js",["233","234","235","236"],[],"C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\styles\\Layouts.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\Components\\Navigation\\Navigation.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\Components\\Expenses\\Expenses.js",["237","238","239"],[],"import React, { useEffect } from 'react'\r\nimport styled from 'styled-components'\r\nimport { useGlobalContext } from '../../context/globalContext';\r\nimport { InnerLayout } from '../../styles/Layouts';\r\nimport Form from '../Form/Form';\r\nimport IncomeItem from '../IncomeItem/IncomeItem';\r\nimport ExpenseForm from './ExpenseForm';\r\n\r\nfunction Expenses() {\r\n    const {addIncome,expenses, getExpenses, deleteExpense, totalExpenses} = useGlobalContext()\r\n\r\n    useEffect(() => {\r\n        if (localStorage.getItem('user')) {\r\n            const user = JSON.parse(localStorage.getItem('user'));\r\n            if (user && user._id){\r\n                console.log(user._id)\r\n                getExpenses(user._id);  \r\n            } else {\r\n                console.error('Invalid user data in localStorage');\r\n            }\r\n        } else{\r\n            console.error('No user found in localStorage');\r\n        }\r\n    }, []);\r\n    const user = JSON.parse(localStorage.getItem('user'));\r\n    return (\r\n        <ExpenseStyled>\r\n            <InnerLayout>\r\n                <h1>Expenses</h1>\r\n                <h2 className=\"total-income\">Total Expense: <span>${totalExpenses()}</span></h2>\r\n                <div className=\"income-content\">\r\n                    <div className=\"form-container\">\r\n                        <ExpenseForm />\r\n                    </div>\r\n                    <div className=\"incomes\">\r\n                        {expenses.map((income) => {\r\n                            const {_id,title, amount, date, category, description, type} = income;\r\n                            console.log(income)\r\n                            return <IncomeItem\r\n                                key={_id}\r\n                                id={_id} \r\n                                userId={user._id}\r\n                                title={title} \r\n                                description={description} \r\n                                amount={amount} \r\n                                date={date} \r\n                                type={type}\r\n                                category={category} \r\n                                indicatorColor=\"var(--color-green)\"\r\n                                deleteItem={deleteExpense}\r\n                            />\r\n                        })}\r\n                    </div>\r\n                </div>\r\n            </InnerLayout>\r\n        </ExpenseStyled>\r\n    )\r\n}\r\n\r\nconst ExpenseStyled = styled.div`\r\n    display: flex;\r\n    overflow: auto;\r\n    .total-income{\r\n        display: flex;\r\n        justify-content: center;\r\n        align-items: center;\r\n        background: #FCF6F9;\r\n        border: 2px solid #FFFFFF;\r\n        box-shadow: 0px 1px 15px rgba(0, 0, 0, 0.06);\r\n        border-radius: 20px;\r\n        padding: 1rem;\r\n        margin: 1rem 0;\r\n        font-size: 2rem;\r\n        gap: .5rem;\r\n        span{\r\n            font-size: 2.5rem;\r\n            font-weight: 800;\r\n            color: var(--color-green);\r\n        }\r\n    }\r\n    .income-content{\r\n        display: flex;\r\n        gap: 2rem;\r\n        .incomes{\r\n            flex: 1;\r\n        }\r\n    }\r\n`;\r\n\r\nexport default Expenses","C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\Components\\Orb\\Orb.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\Components\\Income\\Income.js",["240","241"],[],"C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\Components\\Dashboard\\Dashboard.js",["242"],[],"C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\Components\\Expenses\\ExpenseForm.js",["243"],[],"C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\utils\\useWindowSize.js",[],[],"C:\\Users\\adith\\OneDrive\\Desktop\\expense-Tracker\\frontend\\src\\utils\\menuItems.js",[],[],"C:\\Users\\adith\\One